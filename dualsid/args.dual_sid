def sid_voice_to_addr(voice_index, args):
    # voice_index: 0..5 in dual mode, 0..2 in single mode
    if not args.dual_sid:
        base = args.sid_base1
        v = voice_index  # 0..2
    else:
        if voice_index < 3:
            base = args.sid_base1
            v = voice_index
        else:
            base = args.sid_base2
            v = voice_index - 3

    # SID voice register block is 7 bytes per voice
    return base + v * 7
