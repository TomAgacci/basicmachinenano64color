10 REM MINECRAFT DEMAKE FOR NANO64 - "MICRO MINECRAFT"
20 REM WORLD: 64x32 2D TILEMAP, BLOCK IDS: 0=AIR,1=DIRT,2=STONE,3=GRASS,4=WOOD
30 DIM W(63,31)
40 PX=32: PY=16
50 BLOCKSEL=1
60 GOSUB 5000
70 GOSUB 6000
80 END

5000 REM INIT WORLD (SIMPLE TERRAIN)
5010 FOR Y=0 TO 31
5020   FOR X=0 TO 63
5030     IF Y>24 THEN W(X,Y)=1
5040     IF Y=24 THEN W(X,Y)=3
5050     IF Y<24 THEN W(X,Y)=0
5060   NEXT X
5070 NEXT Y
5080 REM PLACE A TREE
5090 W(10,23)=4: W(10,22)=4: W(10,21)=4
5100 RETURN

6000 REM MAIN LOOP
6010 REM INPUT
6020 K$=INKEY$
6030 IF K$="A" THEN GOSUB 6100
6040 IF K$="D" THEN GOSUB 6110
6050 IF K$="W" THEN GOSUB 6120
6060 IF K$="S" THEN GOSUB 6130
6070 IF K$="Z" THEN GOSUB 6200
6080 IF K$="X" THEN GOSUB 6300
6090 IF K$="C" THEN GOSUB 6400
6095 REM DRAW
6096 GOSUB 7000
6097 GOTO 6000

6100 REM MOVE LEFT
6110 REM MOVE RIGHT
6120 REM MOVE UP (JUMP)
6130 REM MOVE DOWN (FALL)
6101 IF PX>0 THEN PX=PX-1
6102 RETURN
6111 IF PX<63 THEN PX=PX+1
6112 RETURN
6121 IF PY>0 THEN PY=PY-1
6122 RETURN
6131 IF PY<31 THEN PY=PY+1
6132 RETURN

6200 REM BREAK BLOCK IN FRONT
6210 TX=PX: TY=PY+1
6220 IF TY>=0 AND TY<=31 THEN W(TX,TY)=0
6230 RETURN

6300 REM PLACE BLOCK IN FRONT
6310 TX=PX: TY=PY+1
6320 IF TY>=0 AND TY<=31 THEN W(TX,TY)=BLOCKSEL
6330 RETURN

6400 REM CYCLE BLOCK SELECTION
6410 BLOCKSEL=BLOCKSEL+1
6420 IF BLOCKSEL>4 THEN BLOCKSEL=1
6430 RETURN

7000 REM DRAW WORLD (TEXT/PIXEL)
7010 CLS
7020 FOR Y=0 TO 31
7030   FOR X=0 TO 63
7040     B=W(X,Y)
7050     IF B=0 THEN GOSUB 7100
7060     IF B=1 THEN GOSUB 7110
7070     IF B=2 THEN GOSUB 7120
7080     IF B=3 THEN GOSUB 7130
7090     IF B=4 THEN GOSUB 7140
7095   NEXT X
7096 NEXT Y
7097 REM DRAW PLAYER
7098 PSET PX,PY
7099 RETURN

7100 REM DRAW AIR (NO PIXEL)
7101 RETURN

7110 REM DRAW DIRT
7111 PSET X,Y
7112 RETURN

7120 REM DRAW STONE
7121 PSET X,Y
7122 RETURN

7130 REM DRAW GRASS
7131 PSET X,Y
7132 RETURN

7140 REM DRAW WOOD
7141 PSET X,Y
7142 RETURN
